# .env
# ─── LAN ACCESS SETUP ─────────────────────────────────────────────────────────
# Replace 192.168.1.X with your actual local IP address.
# To find it: open Command Prompt → type ipconfig → look for IPv4 Address
# under your Wi-Fi adapter. Example: 192.168.1.5
#
# HOW TO APPLY:
#   1. Replace the IP below with your actual IP
#   2. Place this file at: Brgy2\brgy\.env  (same folder as package.json)
#   3. Restart the frontend: npm start
#
# OTHER DEVICES on the same WiFi can then open:
#   http://192.168.1.X:3000   ← frontend (replace X with your IP)
#   http://192.168.1.X:3001   ← backend API
# ─────────────────────────────────────────────────────────────────────────────

REACT_APP_API_URL=http://192.168.1.X:3001
DISABLE_ESLINT_PLUGIN=true
SKIP_PREFLIGHT_CHECK=true
