# .env
# ─── FIX: ESLint "Plugin react was conflicted between package.json and BaseConfig" ───
# This tells Create React App to skip the ESLint version-check that causes the
# "conflicted between ... node_modules/eslint-config-react-app/base.js and BaseConfig"
# error when a global react-scripts is also installed on the machine.
#
# HOW TO USE:
#   Place this file at:  Brgy2\brgy\.env   (root of the frontend, same folder as package.json)
#   Then restart the dev server: npm start
# ────────────────────────────────────────────────────────────────────────────────────────

DISABLE_ESLINT_PLUGIN=true
SKIP_PREFLIGHT_CHECK=true
